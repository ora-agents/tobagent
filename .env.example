# LangChain Docs Agent Environment Variables

# =============================================================================
# OpenAI-Compatible API (required)
#
# OPENAI_COMPATIBLE_* 仅由后端使用（FastAPI 代理 /api/models）。
# 前端不直接接触这些密钥，模型列表通过后端中转获取。
#
# 支持任何 OpenAI 兼容接口：
#   OpenAI:      https://api.openai.com/v1
#   Ollama:      http://localhost:11434/v1
#   OpenRouter:  https://openrouter.ai/api/v1
#   vLLM:        http://your-vllm-host:8000/v1
# =============================================================================

# 后端读取这些变量代理 /models 请求（不暴露到浏览器）
OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
OPENAI_COMPATIBLE_API_KEY=sk-your_api_key_here
OPENAI_COMPATIBLE_DEFAULT_MODEL=gpt-4o

# 可选：guardrails 使用独立模型（后端专用，不暴露到浏览器）
# 留空则与 OPENAI_COMPATIBLE_DEFAULT_MODEL 相同
OPENAI_GUARDRAILS_MODEL=

# =============================================================================
# LangGraph / LangSmith
# =============================================================================
LANGCHAIN_TRACING_V2=true
LANGSMITH_API_KEY=lsv2_your_langsmith_api_key_here
LANGSMITH_PROJECT=docs-agent

# Comma-separated frontend origins allowed to call the FastAPI sidecar.
# Defaults include localhost dev ports and https://wsrtob.s.odn.cc.
# ALLOWED_ORIGINS=https://your-frontend.example.com
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-frontend.example.com

# Used only by docker-compose.yml when building the frontend image.
# Local Next.js development reads frontend/.env instead.
FRONTEND_LANGGRAPH_API_URL=http://localhost:2025

# Local Aegra PostgreSQL. `aegra dev` creates docker-compose.yml from the
# project name and starts this database automatically when db-check is enabled.
POSTGRES_USER=tobagent
POSTGRES_PASSWORD=tobagent_secret
POSTGRES_DB=tobagent
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Local dev pool limits. Aegra defaults are larger and can exhaust a small
# local Postgres instance if stale reload processes accumulate.
SQLALCHEMY_POOL_SIZE=2
SQLALCHEMY_MAX_OVERFLOW=1
LANGGRAPH_MIN_POOL_SIZE=1
LANGGRAPH_MAX_POOL_SIZE=5

# Optional: write auth/middleware diagnostics as JSONL while debugging SDK calls.
# Keep disabled in normal use because it records agent ids, user ids, and event metadata.
# TOB_AGENT_DEBUG_LOG_FILE=logs/agent-debug.jsonl

# =============================================================================
# Voice Features (DashScope Realtime API — backend only)
#
# Used by FastAPI WebSocket proxy (/ws/voice/asr, /ws/voice/tts).
# The API key stays server-side; the frontend never sees it.
# =============================================================================

# DashScope API Key (required for voice features)
DASHSCOPE_API_KEY=sk-xxx

# ASR model (optional, has default)
# ASR_MODEL=qwen3-asr-flash-realtime-2026-02-10

# TTS model (optional, has default)
# TTS_MODEL=qwen3-tts-instruct-flash-realtime

# TTS voice (optional, has default)
# TTS_VOICE=Cherry

# KWS (Keyword Spotting) configuration
# Override the default model directory (default: ./models/kws)
# KWS_MODEL_DIR=./models/kws
# Number of threads for KWS inference (default: 2)
# KWS_NUM_THREADS=2

# Voice Audio Logging (debug/diagnostics — saves WAV files per session)
# Master switch: set to true to enable audio logging (default: disabled)
# VOICE_AUDIO_LOG_ENABLED=false
# Output directory (default: logs/voice_audio)
# VOICE_AUDIO_LOG_DIR=logs/voice_audio
# Per-stage toggles (default: follow master switch)
# VOICE_AUDIO_LOG_RAW=true      # Raw microphone PCM (accumulated per session)
# VOICE_AUDIO_LOG_VAD=true      # Post-VAD completed speech segments
# VOICE_AUDIO_LOG_TTS=true      # TTS synthesized output audio
