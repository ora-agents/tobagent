# TOB Agent backend environment variables.
#
# This example keeps optional modules disabled by default. Copy .env.minimal
# when you only need the smallest local setup, or copy this file and uncomment
# the module blocks you want to enable.

# =============================================================================
# OpenAI-Compatible API (required for agent/model/RAG features)
#
# OPENAI_COMPATIBLE_* is backend-only. Browser clients fetch models through
# /api/models, so the upstream API key is never exposed to the frontend.
#
# Examples:
#   OpenAI:      https://api.openai.com/v1
#   Ollama:      http://localhost:11434/v1
#   OpenRouter:  https://openrouter.ai/api/v1
#   vLLM:        http://your-vllm-host:8000/v1
# =============================================================================

OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
OPENAI_COMPATIBLE_API_KEY=sk-your_api_key_here
OPENAI_COMPATIBLE_DEFAULT_MODEL=gpt-4o

# Optional model/runtime defaults.
# OPENAI_GUARDRAILS_MODEL=
# MODEL_MAX_RETRIES=2
# MODEL_LIST_CACHE_TTL_SECONDS=300

# =============================================================================
# Security / CORS / frontend URL
# =============================================================================

# Browser sessions are signed and stored in an HttpOnly cookie. Set a stable
# secret in production so sessions survive backend restarts and cannot be
# forged. If unset, the backend generates an in-memory dev secret at startup.
# SESSION_JWT_SECRET=change_me_to_a_random_session_secret
# SESSION_MAX_AGE_SECONDS=2592000
# SESSION_COOKIE_SECURE=true
# Use none with secure=true when the frontend and backend are on different sites.
# SESSION_COOKIE_SAMESITE=lax
# SESSION_COOKIE_DOMAIN=.your-domain.example

# Optional LangGraph/Aegra debugging or deployment gate. When set, direct
# LangGraph SDK requests must include the matching X-Auth-Key header. This is
# not the browser session secret and is not required for normal web login.
# LANGGRAPH_AUTH_SECRET=change_me_to_a_random_langgraph_debug_secret

# Platform administration console. When PLATFORM_ADMIN_TOTP_SECRET is unset,
# all /api/platform-admin endpoints are disabled. Generate a Base32 seed with
# `uv run python -c "import pyotp; print(pyotp.random_base32())"`. To provision
# Google Authenticator, POST to /api/platform-admin/totp/provisioning with
# X-Platform-Admin-Setup-Key equal to this server-only value; never expose it
# in browser code. Registration, password changes, and logout require a
# current six-digit authenticator code; routine login uses the admin password.
# PLATFORM_ADMIN_TOTP_SECRET=JBSWY3DPEHPK3PXP
# PLATFORM_ADMIN_SESSION_MAX_AGE_SECONDS=28800

# The Tauri desktop app normally uses the HttpOnly cookie with HTTPS backends.
# For custom HTTP/LAN backends where cross-site cookies are unreliable, the app
# can request and store a desktop-only session bearer token after login.

# Comma-separated frontend origins allowed to call the FastAPI sidecar.
# Defaults include localhost dev ports and https://wsrtob.s.odn.cc.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-frontend.example.com
# ALLOWED_ORIGINS=https://your-frontend.example.com

# Used only by docker-compose.yml when building the frontend image.
# Local Next.js development reads frontend/.env or frontend/.env.local.
FRONTEND_LANGGRAPH_API_URL=http://localhost:2025

# =============================================================================
# Database (optional; SQLite fallback is used when unset)
# =============================================================================

# DATABASE_URL=postgresql://tobagent:tobagent_secret@localhost:5432/tobagent
# POSTGRES_USER=tobagent
# POSTGRES_PASSWORD=tobagent_secret
# POSTGRES_DB=tobagent
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# Local dev pool limits. Aegra defaults are larger and can exhaust a small
# local Postgres instance if stale reload processes accumulate.
# SQLALCHEMY_POOL_SIZE=2
# SQLALCHEMY_MAX_OVERFLOW=1
# LANGGRAPH_MIN_POOL_SIZE=1
# LANGGRAPH_MAX_POOL_SIZE=5

# Optional: write auth/middleware diagnostics as JSONL while debugging SDK calls.
# Keep disabled in normal use because it records agent ids, user ids, and event metadata.
# TOB_AGENT_DEBUG_LOG_FILE=logs/agent-debug.jsonl

# =============================================================================
# Langfuse tracing (optional observability module)
# =============================================================================

# LANGFUSE_SECRET_KEY=sk-lf-your_secret_key_here
# LANGFUSE_PUBLIC_KEY=pk-lf-your_public_key_here
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# =============================================================================
# SMS Verification (optional Aliyun Dysmsapi SendSms module)
# =============================================================================

# ALIYUN_ACCESS_KEY_ID=your_access_key_id
# ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret
# ALIYUN_SMS_SIGN_NAME=your_sms_sign_name
# ALIYUN_SMS_TEMPLATE_CODE=your_default_verification_template_code
# ALIYUN_SMS_RESET_PASSWORD_TEMPLATE_CODE=your_reset_password_template_code
# ALIYUN_SMS_FORM_HOOK_TEMPLATE_CODE=your_form_hook_template_code
# SMS_HOOK_KEY=change_me_to_a_random_hook_secret
# ALIYUN_SMS_REGION_ID=cn-hangzhou
# SMS_CODE_TTL_SECONDS=300
# SMS_RESEND_INTERVAL_SECONDS=60
# SMS_CODE_HASH_SECRET=change_me
# SMS_DEV_LOG_CODE=false

# =============================================================================
# Knowledge base / RAG storage (optional defaults)
# =============================================================================

# OPENAI_EMBEDDING_MODEL=text-embedding-v3
# EMBEDDING_DIM=1024
# LANCEDB_PATH=/tmp/lancedb_agents
# KNOWLEDGE_DOCUMENTS_PATH=/tmp/tobagent_knowledge_documents

# =============================================================================
# Voice Features (optional DashScope Realtime API module)
#
# Used by FastAPI WebSocket proxy (/ws/voice/asr, /ws/voice/tts).
# The API key stays server-side; the frontend never sees it.
# =============================================================================

# DASHSCOPE_API_KEY=sk-xxx
# ASR_MODEL=qwen3-asr-flash
# TTS_MODEL=qwen3-tts-instruct-flash-realtime
# TTS_VOICE=Cherry

# Voice VAD defaults.
# VOICE_VAD_THRESHOLD=0.5
# VOICE_VAD_MIN_SILENCE_DURATION=0.6
# VOICE_VAD_MIN_SPEECH_DURATION=0.2
# VOICE_VAD_MAX_SPEECH_DURATION=20.0
# VOICE_VAD_PRE_ROLL_SECONDS=0.35
# VOICE_VAD_POST_ROLL_SECONDS=0.15
# VOICE_MIN_ASR_SEGMENT_SECONDS=0.3

# KWS (Keyword Spotting) configuration.
# KWS_MODEL_DIR=./models/kws
# KWS_NUM_THREADS=2

# Speaker verification runs in the speaker service container.
# Docker Compose backend containers use http://speaker:8090 on the private
# Compose network. Host-run dev backends normally use http://127.0.0.1:8090.
# VOICE_SPEAKER_VERIFICATION_ENABLED=false
# SPEAKER_SERVICE_URL=http://speaker:8090
# SPEAKER_PORT=8090
# VOICE_SPEAKER_PROFILE_THRESHOLD=0.72
# VOICE_SPEAKER_PROFILE_MIN_SECONDS=1.5
# VOICE_SPEAKER_VERIFY_MIN_SECONDS=0.5
# VOICE_SPEAKER_PROFILE_MODEL_SOURCE=speechbrain/spkrec-ecapa-voxceleb
# VOICE_SPEAKER_PROFILE_MODEL_DIR=/app/models/speechbrain-spkrec-ecapa-voxceleb
# SPEAKER_MAX_SAMPLES=1700000

# Voice Audio Logging (debug/diagnostics; saves WAV files per session).
# VOICE_AUDIO_LOG_ENABLED=false
# VOICE_AUDIO_LOG_DIR=logs/voice_audio
# VOICE_AUDIO_LOG_RAW=true
# VOICE_AUDIO_LOG_VAD=true
# VOICE_AUDIO_LOG_TTS=true
