# LangChain Docs Agent Environment Variables

# =============================================================================
# OpenAI-Compatible API (required)
#
# NEXT_PUBLIC_* 变量同时服务前端（浏览器获取模型列表）和后端（Python 调用模型）。
# 只需配置这一套，无需重复。
#
# 支持任何 OpenAI 兼容接口：
#   OpenAI:      https://api.openai.com/v1
#   Ollama:      http://localhost:11434/v1
#   OpenRouter:  https://openrouter.ai/api/v1
#   vLLM:        http://your-vllm-host:8000/v1
# =============================================================================

NEXT_PUBLIC_OPENAI_BASE_URL=https://api.openai.com/v1
NEXT_PUBLIC_OPENAI_API_KEY=sk-your_api_key_here
NEXT_PUBLIC_OPENAI_DEFAULT_MODEL=gpt-4o

# 可选：guardrails 使用独立模型（后端专用，不暴露到浏览器）
# 留空则与 NEXT_PUBLIC_OPENAI_DEFAULT_MODEL 相同
OPENAI_GUARDRAILS_MODEL=

# =============================================================================
# LangGraph / LangSmith
# =============================================================================
NEXT_PUBLIC_LANGGRAPH_API_URL=http://localhost:2024
LANGCHAIN_TRACING_V2=true
LANGSMITH_API_KEY=lsv2_your_langsmith_api_key_here
LANGSMITH_PROJECT=docs-agent
