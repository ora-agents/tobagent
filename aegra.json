{
  "name": "tobagent",
  "dependencies": ["."],
  "graphs": {
    "generic_agent": "./src/agent/generic_agent.py:generic_agent",
    "agent_builder": "./src/agent/agent_builder.py:agent_builder"
  },
  "env": ".env",
  "auth": {
    "path": "./src/api/auth.py:auth",
    "disable_studio_auth": true
  },
  "http": {
    "app": "./src/api/server.py:app",
    "cors": {
      "allow_origins": [
        "http://localhost:3000",
        "http://127.0.0.1:3000",
        "http://localhost:3001",
        "http://127.0.0.1:3001",
        "https://wsrtob.s.odn.cc",
        "https://wsr.wsiri.cn",
        "https://gen.wsiri.cn"
      ],
      "allow_methods": ["*"],
      "allow_headers": ["*"]
    }
  },
  "image_distro": "wolfi",
  "config": {
    "recursion_limit": 100
  },
  "checkpointer": {
    "ttl": {
      "default_ttl": 604800,
      "sweep_interval_minutes": 60,
      "strategy": "delete"
    }
  }
}
