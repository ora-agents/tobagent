{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TOB Agent",
  "version": "0.1.0",
  "identifier": "cn.wsiri.tobagent",
  "build": {
    "beforeDevCommand": "bun run dev:desktop:if-needed",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "bun run build:desktop",
    "frontendDist": "../out"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "TOB Agent",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {}
  }
}
