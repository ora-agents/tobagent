# Minimal backend environment for local development.
# Copy to .env and replace the API key/model service values.

OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
OPENAI_COMPATIBLE_API_KEY=sk-your_api_key_here
OPENAI_COMPATIBLE_DEFAULT_MODEL=gpt-4o

# Optional frontend origins. Localhost defaults are already allowed.
# CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
